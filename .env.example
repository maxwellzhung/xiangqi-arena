# Han vs Chu environment reference
# Copy this file to .env for local development. Values marked "production"
# must be injected by the deployment platform and never committed.

# Browser-visible URL used by the web client to reach the realtime server.
NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001

# Canonical web origin used when the game server creates private-room join URLs.
PUBLIC_WEB_ORIGIN=http://localhost:3000

# Realtime server bind address. The server defaults to 0.0.0.0.
HOST=0.0.0.0

# Realtime server port. Leave commented in a shared root .env so the web
# server can retain its port 3000 default; set PORT=3001 in the game-server
# process or container environment.
# PORT=3001

# Comma-separated exact web origins allowed to use the realtime HTTP/SSE server.
# Production must use HTTPS origins and must not use a wildcard.
GAME_SERVER_ALLOWED_ORIGINS=http://localhost:3000

# Deployment mode. Containers set this to production; local development may
# leave it unset so safe development defaults remain available.
# NODE_ENV=production

# Local PostgreSQL container settings. The password is development-only.
POSTGRES_DB=xiangqi_arena
POSTGRES_USER=xiangqi
POSTGRES_PASSWORD=xiangqi_local_only
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1

# PostgreSQL connection string reserved for the durable repository adapter.
# Replace the credentials and require TLS in production.
DATABASE_URL=postgresql://xiangqi:xiangqi_local_only@localhost:5432/xiangqi_arena

# Local Redis container port and provider-neutral connection string. Redis is
# reserved for distributed matchmaking, presence, and rate limiting.
REDIS_PORT=6379
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_URL=redis://localhost:6379

# Production-only secret used to sign persistent guest/session identifiers.
# Generate at least 32 random bytes; never reuse this example text.
# SESSION_SECRET=replace-with-at-least-32-random-bytes

# Optional future registered-account adapters. Guest play does not require
# these values. Redirect URIs must be exact and HTTPS in production.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# EMAIL_FROM=
# EMAIL_PROVIDER_API_KEY=
